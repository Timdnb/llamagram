# Path to local llama-server binary.
# IMPORTANT: Set this to your llama.cpp build location.
# Example: LLAMA_SERVER_BIN=$HOME/projects/llama.cpp/build/bin/llama-server
LLAMA_SERVER_BIN=/path/to/llama.cpp/build/bin/llama-server

# Ports used by Llamagram stack.
LLAMA_PORT=${LLAMA_PORT:-8002}
MCP_PROXY_PORT=${MCP_PROXY_PORT:-8001}

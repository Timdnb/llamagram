# -------- llama-server required --------
# Used by llm.sh as --model and --alias
AGENT_LLAMA_MODEL=/path/to/your/model.gguf
AGENT_LLAMA_ALIAS=your/model-alias

# -------- llama-server optional flags --------
# Convention: AGENT_LLAMA_FLAG_<UPPER_SNAKE_CASE>
# Mapping rule: AGENT_LLAMA_FLAG_CTX_SIZE -> --ctx-size
# Bool-like values true/1/yes/on become switch-only flags (e.g. --jinja)
AGENT_LLAMA_FLAG_CTX_SIZE=32768
AGENT_LLAMA_FLAG_TEMP=0.7
AGENT_LLAMA_FLAG_TOP_P=0.95
AGENT_LLAMA_FLAG_TOP_K=20
AGENT_LLAMA_FLAG_MIN_P=0.0
# AGENT_LLAMA_FLAG_N_GPU_LAYERS=99
# AGENT_LLAMA_FLAG_MMPROJ=/path/to/your/mmproj.gguf
# AGENT_LLAMA_FLAG_JINJA=true

# -------- MCP / tooling settings --------
# Used by agents/<name>/mcp.config.json placeholders.
AGENT_MCP_LOCAL_TIMEZONE=Europe/Amsterdam
